<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eventqr_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Back"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/eventqr_indigo" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Edit Profile"
                android:textColor="@color/eventqr_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="Save"
                android:src="@android:drawable/ic_menu_save"
                android:tint="@color/eventqr_indigo" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <View
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:background="@drawable/bg_chip" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Change Photo"
                android:textColor="@color/eventqr_indigo"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="@color/eventqr_text"
                android:textStyle="bold" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Enter full name"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Email"
                android:textColor="@color/eventqr_text"
                android:textStyle="bold" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:enabled="false"
                android:hint="email@example.com"
                android:paddingHorizontal="16dp"
                android:textColor="@color/eventqr_muted" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Phone"
                android:textColor="@color/eventqr_text"
                android:textStyle="bold" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Enter phone number"
                android:inputType="phone"
                android:paddingHorizontal="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Bio"
                android:textColor="@color/eventqr_text"
                android:textStyle="bold" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Tell people about your event interests"
                android:inputType="textMultiLine"
                android:padding="16dp" />
        </LinearLayout>

        <Button
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_primary_button"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textColor="@color/eventqr_card"
            android:textStyle="bold" />
    </LinearLayout>

</ScrollView>
