<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:text="Manage Events"
        android:textColor="@color/black"
        android:textSize="26sp"
        android:textStyle="bold" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp">

            <Button
                android:id="@+id/btnLoadManageEvents"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_rounded"
                android:text="Refresh Events"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <EditText
                android:id="@+id/edtManageEventId"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Event ID"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Title"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventDescription"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:gravity="top|start"
                android:hint="Description"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:padding="14dp" />

            <EditText
                android:id="@+id/edtManageEventLocation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Location"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventRegOpen"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Registration open ISO-8601"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventRegClose"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Registration close ISO-8601"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventStart"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Event start ISO-8601"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventEnd"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Event end ISO-8601"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventCapacity"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Capacity"
                android:inputType="number"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventOrganizerId"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Organizer user ID"
                android:padding="14dp"
                android:singleLine="true" />

            <CheckBox
                android:id="@+id/chkManageEventRewards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Rewards enabled" />

            <CheckBox
                android:id="@+id/chkManageEventApproved"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Approve on review" />

            <EditText
                android:id="@+id/edtManageEventReviewerId"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Reviewer user ID"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtManageEventRejectionReason"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:gravity="top|start"
                android:hint="Rejection reason"
                android:inputType="textMultiLine"
                android:padding="14dp" />

            <Button
                android:id="@+id/btnSubmitManageEvent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_rounded"
                android:text="Create Event"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnReviewManageEvent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/transparent_alt"
                android:text="Review Event"
                android:textAllCaps="false"
                android:textColor="#1F2937" />

            <Button
                android:id="@+id/btnActivateManageEvent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/transparent_alt"
                android:text="Activate Event"
                android:textAllCaps="false"
                android:textColor="#1F2937" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerManageEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp" />
</LinearLayout>